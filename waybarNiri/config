{
  "layer": "bot",
  "spacing": 0,
  "height": 0,
  "margin-bottom": 0,
  "margin-top": 15,
  "position": "top",
  "margin-right": 225,
  "margin-left": 225,
  "modules-left": [
    "custom/powerprofile",
    "clock",
    "custom/niri-workspaces",
    "hyprland/workspaces",
    "sway/workspaces"
  ],
  "modules-center": [
  ],
  "modules-right": [
    "battery",
    "pulseaudio",
    "custom/resolution"
  ],
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "sway/workspaces": {
    "disable-scroll": true,
    "all-outputs": false,
    "tooltip": false
  },
  "custom/niri-workspaces": {
    "exec": "~/.config/waybar/custom_modules/niri-workspaces.py",
    "return-type": "json",
    "on-scroll-up": "niri msg action focus-workspace-up",
    "on-scroll-down": "niri msg action focus-workspace-down",
    "on-click": "niri msg action toggle-overview",
    "tooltip": false
  },
  "custom/applauncher": {
    "format": "〇",
    "on-click": "pgrep wofi >/dev/null 2>&1 && killall wofi || wofi --show drun --location=top -y 15",
    "tooltip": false
  },
  "tray": {
    "spacing": 10,
    "tooltip": false
  },
  "clock": {
    "format": "{:%H:%M}",
    "tooltip": false
  },
  "network": {
    "format-wifi": " {bandwidthDownBits}",
    "format-ethernet": " {bandwidthDownBits}",
    "format-disconnected": "󰤮 No Network",
    "interval": 5,
    "tooltip": false
  },
  "pulseaudio": {
    "scroll-step": 5,
    "max-volume": 150,
    "format": "{icon} {volume}%",
    "format-bluetooth": "{icon} {volume}%",
    "format-icons": [
      "",
      "",
      " "
    ],
    "nospacing": 1,
    "format-muted": " ",
    "on-click": "pavucontrol",
    "tooltip": false
  },
  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰂄{capacity}%",
    "format-alt": "{icon} {time}",
    "format-full": "󱈑 {capacity}%",
    "format-icons": [
      "󱊡",
      "󱊢",
      "󱊣"
    ]
  },
  "custom/powerprofile": {
    "exec": "~/.config/waybar/custom_modules/power-profile.sh",
    "interval": 5,
    "on-click": "~/.config/waybar/custom_modules/power-profile.sh toggle",
    "tooltip": false
  },
  "custom/resolution": {
    "exec": "~/.config/waybar/custom_modules/res-toggle.sh",
    "interval": 5,
    "on-click": "~/.config/waybar/custom_modules/res-toggle.sh toggle",
    "tooltip": false
  }
}
